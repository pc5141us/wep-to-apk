{
  "version": 2,
  "builds": [
    {
      "src": "builder/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "builder/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "builder/server.js"
    },
    {
      "src": "/",
      "dest": "/builder/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/builder/public/$1"
    }
  ]
}
